# .env.example — Template variabili d'ambiente per Cruscotto Italia
#
# Uso:
#   1. Copia questo file: cp .env.example .env
#   2. Compila i valori sotto con le tue credenziali Cloudflare
#   3. Carica in shell prima di lanciare gli ETL:
#        set -a; source .env; set +a
#
# Per la procedura di creazione delle credenziali, vedi docs/SECRETS.md
#
# IMPORTANTE: il file .env è in .gitignore e NON viene committato.
# Non condividere mai questi valori (sono credenziali piene).

# ---------------------------------------------------------------------------
# Cloudflare R2 — usato dagli ETL Python per leggere/scrivere shard su R2
# Necessario solo se vuoi pushare dati su un bucket R2 (--target=r2).
# Per smoke test e sviluppo locale (--target=local) NON serve nulla.
# ---------------------------------------------------------------------------

# Account ID Cloudflare (32 caratteri esadecimali)
# Dashboard Cloudflare → sidebar destra → Account ID
R2_ACCOUNT_ID=

# Coppia access key / secret key R2 (S3-compatible)
# Dashboard Cloudflare → R2 → Manage R2 API Tokens → Create API Token
# Permessi richiesti: Object Read & Write sul bucket
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Nome bucket R2. Default 'cruscotto-italia-data'. Lascia vuoto per usare il default.
# R2_BUCKET=cruscotto-italia-data

# ---------------------------------------------------------------------------
# Wrangler — usato per deploy del Worker (cd worker && wrangler deploy)
# Necessario solo se NON usi 'wrangler login' interattivo.
# ---------------------------------------------------------------------------

# Stesso valore di R2_ACCOUNT_ID
# CLOUDFLARE_ACCOUNT_ID=

# API token Cloudflare con scope: Workers Scripts:Edit, Workers KV Storage:Edit
# Dashboard → My Profile → API Tokens → Create Token → template "Edit Cloudflare Workers"
# CLOUDFLARE_API_TOKEN=

# ---------------------------------------------------------------------------
# Worker admin — usato dagli ETL per chiamare /admin/cache/purge a fine pipeline
# Genera un valore casuale: openssl rand -base64 48
# Lo stesso valore va impostato anche come Worker secret:
#   cd worker && wrangler secret put WORKER_ADMIN_TOKEN
# ---------------------------------------------------------------------------

# WORKER_ADMIN_TOKEN=
